generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TALENT
  RECRUITER
  ADMIN
}

enum Visibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum Foot {
  LEFT
  RIGHT
  BOTH
}

enum VideoStatus {
  PROCESSING
  READY
  FAILED
}

enum PricingTier {
  A
  B
  C
  CUSTOM
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(TALENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  talentProfile     TalentProfile?
  recruiterProfile  RecruiterProfile?
  accessGrants      AccessGrant[]     @relation("RecruiterGrants")
  payments          Payment[]
  auditLogs         AuditLog[]
  accounts          Account[]
  sessions          Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TalentProfile {
  id              String       @id @default(cuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  slug            String       @unique
  displayName     String
  headline        String?
  bio             String?      @db.Text
  positions       String[]
  country         String?
  city            String?
  birthDate       DateTime?
  heightCm        Int?
  foot            Foot?
  languages       String[]
  team            String?
  league          String?
  statsJson       Json?
  tags            String[]

  visibility      Visibility   @default(PUBLIC)
  published       Boolean      @default(false)
  pricingTier     PricingTier  @default(A)
  customPriceCents Int?

  guardianConsentId String?    @unique
  guardianConsent   GuardianConsent? @relation(fields: [guardianConsentId], references: [id])

  privateContact  PrivateContact?
  media           MediaAsset[]
  accessGrants    AccessGrant[]
  payments        Payment[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model PrivateContact {
  id          String        @id @default(cuid())
  talentId    String        @unique
  talent      TalentProfile @relation(fields: [talentId], references: [id], onDelete: Cascade)

  email       String?
  phone       String?
  agentName   String?
  agentEmail  String?
  agentPhone  String?
  address     String?
  notes       String?       @db.Text
  revealEmail Boolean       @default(true)
  revealPhone Boolean       @default(true)
  agentOnly   Boolean       @default(false)
}

model GuardianConsent {
  id           String   @id @default(cuid())
  guardianName String
  relationship String
  email        String
  signedAt     DateTime?
  ipHash       String?
  documentUrl  String?
  token        String   @unique @default(cuid())
  createdAt    DateTime @default(now())

  talentProfile TalentProfile?
}

model RecruiterProfile {
  id        String  @id @default(cuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  orgName   String?
  roleTitle String?
  website   String?
  country   String?
  verified  Boolean @default(false)

  email     String?
  phone     String?
}

model MediaAsset {
  id          String        @id @default(cuid())
  talentId    String
  talent      TalentProfile @relation(fields: [talentId], references: [id], onDelete: Cascade)

  type        String
  title       String?
  url         String
  provider    String        @default("cloudflare")
  providerId  String?
  status      VideoStatus   @default(PROCESSING)
  thumbUrl    String?
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
}

model AccessGrant {
  id          String        @id @default(cuid())
  recruiterId String
  talentId    String
  recruiter   User          @relation("RecruiterGrants", fields: [recruiterId], references: [id], onDelete: Cascade)
  talent      TalentProfile @relation(fields: [talentId], references: [id], onDelete: Cascade)
  revoked     Boolean       @default(false)
  createdAt   DateTime      @default(now())
  expiresAt   DateTime?

  @@unique([recruiterId, talentId])
}

model Payment {
  id              String        @id @default(cuid())
  recruiterId     String
  talentId        String
  recruiter       User          @relation(fields: [recruiterId], references: [id])
  talent          TalentProfile @relation(fields: [talentId], references: [id])
  amountCents     Int
  currency        String        @default("eur")
  stripeSessionId String        @unique
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  refundedAt      DateTime?
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  talentId  String?
  metadata  Json?
  ipHash    String?
  createdAt DateTime @default(now())
}

model SiteSettings {
  id                String @id @default("default")
  tierAPriceCents   Int    @default(5000)
  tierBPriceCents   Int    @default(7500)
  tierCPriceCents   Int    @default(9900)
  refundWindowDays  Int    @default(3)
  stripeLiveMode    Boolean @default(false)
}
